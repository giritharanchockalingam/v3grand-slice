{
  "name": "v3grand",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev --parallel",
    "db:migrate": "pnpm --filter @v3grand/db migrate",
    "db:seed": "pnpm --filter @v3grand/db seed",
    "migrate:supabase": "pnpm --filter @v3grand/db migrate:supabase"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  }
}
