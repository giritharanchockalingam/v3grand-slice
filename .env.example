# ─── V3 Grand Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in values

# PostgreSQL connection string
DATABASE_URL=postgres://youruser@localhost:5432/v3grand

# API server port
PORT=3001

# JWT secret (generate a random 64-char hex string)
JWT_SECRET=change-me-to-something-random-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Next.js public API URL
NEXT_PUBLIC_API_URL=http://localhost:3001
