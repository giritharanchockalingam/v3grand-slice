# ─── V3 Grand Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in values

# PostgreSQL connection string
# With Docker Compose (packages/infra): port 5433 to avoid conflict with local Postgres on 5432
DATABASE_URL=postgres://postgres:postgres@localhost:5433/v3grand

# API server port
PORT=3001

# JWT secret (generate a random 64-char hex string for production)
JWT_SECRET=change-me-to-something-random-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Next.js public API URL (used by the UI to call the API)
NEXT_PUBLIC_API_URL=http://localhost:3001

# NATS server URL for JetStream event bus (optional; when set, API publishes/subscribes to NATS)
# With Docker Compose (packages/infra): nats://localhost:4222
NATS_URL=nats://localhost:4222
